# =============================================================================
# MinimalKlondike — 关卡生成参数文件（UTF-8）
#
# 用法：复制为 launch.args，与可执行文件同目录；不带命令行参数启动时会自动读取。
#
# 语法：以 # 开头的整行是说明；行内 # 仅在双引号外视为注释。开关与数值一般各占一行。
# 入库规则：仅当求解结果为 Solved 或 Minimal，且通过下方已启用的筛选条件时，牌串才会写入输出文件。
# =============================================================================

# -----------------------------------------------------------------------------
# 必选：进入关卡生成模式（勿删、勿改）
# -----------------------------------------------------------------------------
--generate

# -----------------------------------------------------------------------------
# 尝试局数：随机发牌并求解多少次；越大越容易攒够合格局，但耗时与 CPU 占用越高
# -----------------------------------------------------------------------------
--attempts
1000

# -----------------------------------------------------------------------------
# 输出文件：合格牌串追加写入。
# 若只写文件名、不写目录，则目录为「可执行文件所在文件夹」。
# 每次运行会在主文件名与扩展名之间自动插入 _yyyyMMdd-HHmmss-fff（毫秒），避免多次运行互相覆盖。
# -----------------------------------------------------------------------------
--out
qualified_deals.txt

# -----------------------------------------------------------------------------
# -D：每次从库存翻到废牌的张数（1 或 3 等），与日常接龙规则一致
# -----------------------------------------------------------------------------
-D
1

# -----------------------------------------------------------------------------
# -S：单次求解最多展开多少个搜索结点；越大越可能求出解，但内存与时间开销更高（约每 2200 万结点近 1GB 量级，视环境而定）
# -----------------------------------------------------------------------------
-S
50000000

# -----------------------------------------------------------------------------
# --max-moves：传给 Board.Solve 的「步数」上界，用于搜索剪枝；过小可能频繁求不到解
# -----------------------------------------------------------------------------
--max-moves
250

# -----------------------------------------------------------------------------
# --max-rounds：传给 Board.Solve 的「完整过完库存次数」上界；过小可能截断可解局面
# -----------------------------------------------------------------------------
--max-rounds
15

# -----------------------------------------------------------------------------
# --green-felt：使用与 Green Felt 网站一致的洗牌方式发牌；不要写数值，需要时取消下一行开头的 #（与默认 Shuffle 二选一）
# -----------------------------------------------------------------------------
# --green-felt

# =============================================================================
# 筛选条件（全部是可选的）
#
# 格式 L,R 表示左开右闭区间 (L,R]：只接受「指标值 > L 且 ≤ R」。若 L 与 R 相等，表示只接受恰好等于该整数。
# 启用某项：说明行可始终带行首 #；须同时去掉「--filter-…」行与「L,R」行这两行的行首 #。
# =============================================================================

# 【关键牌盖牌深度】只在盖牌里看 A、2、K；每张牌统计「它上面还压着几张盖牌」，再在七列里取全局最大值；只保留该最大值落在 (L,R] 内的局
# --filter-key-depth
# 0,5

# 【首次翻盖步数】七列盖牌总张数第一次减少的那一「步」上，累计牌桌步数 + 牌库步数之和；只保留落在 (L,R] 内的局
# --filter-first-reveal
# 0,100

# 【通关步数】与引擎 MovesMade 一致（一步 ≈ 一次 MakeMove 折算后的计数）；只保留落在 (L,R] 内的局
# --filter-solve-moves
# 50,200

# 【全翻开步数】七列盖牌全部翻开的那一「步」上，累计牌桌步数 + 牌库步数之和；只保留落在 (L,R] 内的局
# --filter-all-revealed
# 0,100

# 【库存 A 张数】开局时库存（未翻部分）里 A 的张数；只保留落在 (L,R] 内的局
# --filter-stock-aces
# 0,1

# 【桌面明牌 A 张数】开局时七列桌面明牌区域里 A 的张数；只保留落在 (L,R] 内的局
# --filter-visible-aces
# 0,1

# 【开局桌面可走动法数】开局时「从某列桌面可移动的合法走法」条数；只保留落在 (L,R] 内的局
# --filter-movable-tableau
# 0,3

# 【盖牌三连同色窗数】七列盖牌中，长度为 3 的滑动窗口里「连续 3 张同色（全红或全黑）」的个数（可重叠）；只保留落在 (L,R] 内的局
# --filter-facedown-triple-samecolor
# 0,2

# 【盖牌四连同色窗数】同上，连续 4 张同色、长度为 4 的滑动窗口个数（可重叠）；只保留落在 (L,R] 内的局
# --filter-facedown-quadruple-samecolor
# 0,1
